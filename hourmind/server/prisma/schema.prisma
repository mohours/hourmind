// 告诉 Prisma 生成 JavaScript 客户端代码
generator client {
  provider = "prisma-client-js"
}

// SQLite 文件型数据库，数据存到 prisma/db/hourmind.db 这个文件里
datasource db {
  provider = "sqlite"
  url      = "file:./db/hourmind.db"
}

// 系统配置表（key-value 结构，一个 key 一行，存密码哈希等）
model AppConfig {
  key   String @id
  value String
}

// AI 厂商（OpenAI、Claude、DeepSeek 等）
model AiProvider {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  baseUrl   String
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  apiKeys   ApiKey[]
}

// 用户添加的 API Key
model ApiKey {
  id           String             @id @default(uuid())
  providerId   String
  provider     AiProvider         @relation(fields: [providerId], references: [id])
  alias        String
  encryptedKey String
  keySuffix    String
  tags         String             @default("[]")
  status       String             @default("active")
  isDeleted    Boolean            @default(false)
  deletedAt    DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  testLogs     KeyTestLog[]
  usageRecords TokenUsageRecord[]
}

// Key 测试记录
model KeyTestLog {
  id           String   @id @default(uuid())
  keyId        String
  key          ApiKey   @relation(fields: [keyId], references: [id])
  isSuccess    Boolean
  latencyMs    Int
  errorMessage String?
  testedAt     DateTime @default(now())
}

// Token 用量记录
model TokenUsageRecord {
  id                 String   @id @default(uuid())
  keyId              String
  key                ApiKey   @relation(fields: [keyId], references: [id])
  modelName          String
  promptTokens       Int
  completionTokens   Int
  estimatedCostCents Int      @default(0)
  recordedAt         DateTime @default(now())
  sessionId          String?
}

// 会话
model Conversation {
  id           String            @id @default(uuid())
  title        String
  model        String
  status       String            @default("active")
  isPinned     Boolean           @default(false)
  isStarred    Boolean           @default(false)
  totalTokens  Int               @default(0)
  messageCount Int               @default(0)
  summary      String?                               // AI 生成的会话摘要（200字以内）
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  messages     Message[]
  tags         ConversationTag[]                      // 关联的标签
}

// 消息
model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String
  content        String
  model          String?
  tokenCount     Int?
  metadata       String       @default("{}")
  createdAt      DateTime     @default(now())
}

// 会话标签关联表（多对多）
model ConversationTag {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  tag            String                               // 标签名，如 "工作"、"学习"、"项目A"
  createdAt      DateTime     @default(now())

  @@unique([conversationId, tag])                     // 同一会话不能重复打同一个标签
  @@index([tag])                                      // 按标签名查询时加索引
}

// ==================== 个人待办事项 ====================
// 任务表：用户创建的任务，支持优先级、状态、截止日期、重复规则
model Task {
  id                   String    @id @default(uuid())
  title                String                           // 任务标题
  description          String?                          // 详细描述（可选）
  priority             String                           // 优先级：high / medium / low
  status               String                           // 状态：todo / in_progress / done / archived
  dueDate              DateTime?                        // 截止日期（可选）
  completedAt          DateTime?                        // 完成时间
  isRecurring          Boolean   @default(false)        // 是否重复任务
  recurRule            String?                          // 重复规则（cron 表达式）
  tags                 String    @default("[]")         // 标签（JSON 数组字符串）
  source               String    @default("manual")     // 来源：manual / chat_extracted（从对话提取）
  sourceConversationId String?                          // 来源会话 ID
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  subtasks             Subtask[]                        // 关联的子任务列表
}

// 子任务表：一个任务可以拆成多个子步骤
model Subtask {
  id          String   @id @default(uuid())
  taskId      String                                      // 所属任务 ID
  task        Task     @relation(fields: [taskId], references: [id])  // 关联任务
  title       String                                      // 子任务标题
  isCompleted Boolean  @default(false)                    // 是否完成
  order       Int                                         // 排序序号（0, 1, 2...）
  createdAt   DateTime @default(now())
}

// ==================== 个人知识库（Second Brain）====================
// 知识文档：用户上传或手动创建的文档
model KnowledgeDocument {
  id        String            @id @default(uuid())
  title     String                                          // 文档标题
  content   String                                          // 文档全文内容
  summary   String?                                         // AI 自动生成的摘要
  filePath  String?                                         // 原始文件路径（上传的文件存在 data/knowledge_files/）
  fileType  String                                          // 文件类型：manual / md / txt / pdf / docx
  fileSize  Int?                                            // 文件大小（字节）
  isIndexed Boolean           @default(false)               // 是否已解析（上传文件需要解析内容）
  tags      String            @default("[]")                // 标签（JSON 数组字符串）
  folder    String?                                         // 所属文件夹
  metadata  String            @default("{}")                // 扩展元数据（JSON）
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  cards     KnowledgeCard[]                                 // 关联的知识卡片
}

// 知识卡片：文档中摘录的精华片段，可以独立查看和管理
model KnowledgeCard {
  id         String            @id @default(uuid())
  documentId String                                          // 所属文档 ID
  document   KnowledgeDocument @relation(fields: [documentId], references: [id])
  title      String                                          // 卡片标题
  content    String                                          // 卡片内容（富文本/Markdown）
  tags       String            @default("[]")                // 标签
  isPinned   Boolean           @default(false)               // 是否置顶
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}
